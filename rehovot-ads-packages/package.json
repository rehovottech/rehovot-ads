{
  "name": "@rehovottech/capacitor-ads",
  "version": "0.1.0",
  "description": "Reusable Capacitor ad bridge for native SDK backends.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "android",
    "ios",
    "src",
    "dist",
    "README.md",
    "CapacitorAds.podspec"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs && tsc -p tsconfig.json --emitDeclarationOnly --declarationDir dist/types",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.4.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "rollup": "^4.34.0",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "capacitor",
    "ionic",
    "ads",
    "bridge",
    "mediation",
    "levelplay"
  ],
  "license": "MIT"
}
